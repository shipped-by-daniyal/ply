---
// Handwritten swatch used by the GENERATED token reference pages (ADR-0009).
// Renders a light/dark split chip so both mode values are visible at once.
interface Props {
  light: string;
  dark?: string;
}
const { light, dark } = Astro.props;
---

<span class="ply-swatch" title={dark ? `light ${light} · dark ${dark}` : light}>
  <span style={`box-shadow: inset 0 0 0 999px ${light}`}></span>
  {dark && <span style={`box-shadow: inset 0 0 0 999px ${dark}`}></span>}
</span>

<style>
  .ply-swatch {
    display: inline-flex;
    inline-size: 2.6rem;
    block-size: 1.3rem;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, currentColor 25%, transparent);
    vertical-align: middle;
  }
  .ply-swatch > span {
    flex: 1;
    /* checkerboard shows through alpha values (the inset box-shadow composites on top) */
    background-image: linear-gradient(45deg, #ccc 25%, transparent 25%, transparent 75%, #ccc 75%),
      linear-gradient(45deg, #ccc 25%, #fff 25%, #fff 75%, #ccc 75%);
    background-size: 8px 8px;
    background-position: 0 0, 4px 4px;
  }
</style>
